# Git LFS - Track large data files
# See https://git-lfs.github.com/

# Geospatial
*.shp filter=lfs diff=lfs merge=lfs -text
*.shx filter=lfs diff=lfs merge=lfs -text
*.dbf filter=lfs diff=lfs merge=lfs -text
*.prj filter=lfs diff=lfs merge=lfs -text
*.geojson filter=lfs diff=lfs merge=lfs -text

# Large data formats
*.parquet filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.hdf5 filter=lfs diff=lfs merge=lfs -text
*.feather filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
*.pickle filter=lfs diff=lfs merge=lfs -text

# Large CSVs in shared data only (project CSVs are gitignored)
data/shared/**/*.csv filter=lfs diff=lfs merge=lfs -text
data/shared/**/*.xlsx filter=lfs diff=lfs merge=lfs -text
data/shared/**/*.zip filter=lfs diff=lfs merge=lfs -text
