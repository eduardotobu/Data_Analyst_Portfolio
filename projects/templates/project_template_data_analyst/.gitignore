# --- 🐍 Python & uv Core ---
__pycache__/
*.py[cod]
*$py.class
.venv/
.python-version

# --- 📓 Jupyter Notebooks ---
# Ignore autosave folders (they generate a lot of noise in git)
.ipynb_checkpoints/
*/.ipynb_checkpoints/
# Optional: Ignore HTML or PDF outputs if you generate them
*.html
*.pdf

# --- 📊 Data (SECURITY BLOCK) ---
# Ignore common data formats to prevent leaks or heavy repositories
*.csv
*.tsv
*.xlsx
*.xls
*.json
*.xml
*.parquet
*.feather
*.pkl
*.pickle
*.h5
*.hdf5

# Generated images (Optional: Uncomment if you generate thousands of plots)
# *.png
# *.jpg
# *.svg

# Compressed files
*.zip
*.tar.gz
*.rar
*.7z

# Specific data folders (Best practices)
data/
datasets/
raw_data/
processed_data/
outputs/
models/

# --- 🔒 Secrets and Configuration (VERY IMPORTANT) ---
# Never upload passwords or API keys
.env
.env.local
config.py
secrets.yaml
credentials.json

# --- 💻 Operating System ---
.DS_Store
Thumbs.db